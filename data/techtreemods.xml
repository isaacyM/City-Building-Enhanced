    <!-- Infantry Focus Unlocks -->
    <tech mergeMode="add" name="ModConscription" type="Normal">
        <dbid>90104</dbid>
        <displaynameid>990040</displaynameid>
        <rollovertextid>990041</rollovertextid>
        <researchpoints>40.0000</researchpoints>
        <status>UNOBTAINABLE</status>
        <icon>resources\images\icons\techs\Squared Icons\Conscripts_companies.png</icon>

        <allowedage>1</allowedage>
        <cost resourcetype="Food">100.0000</cost>
        <cost resourcetype="Wood">200.0000</cost>
        <cost resourcetype="Gold">100.0000</cost>

        <effects>
            <!-- 10% cheaper infantry -->
            <effect type="Data" amount="0.90" subtype="Cost" resource="Food"
                relativity="BasePercent">
                <target type="ProtoUnit">AbstractInfantry</target>
            </effect>

            <effect type="Data" amount="0.90" subtype="Cost" resource="Wood"
                relativity="BasePercent">
                <target type="ProtoUnit">AbstractInfantry</target>
            </effect>

            <effect type="Data" amount="0.90" subtype="Cost" resource="Gold"
                relativity="BasePercent">
                <target type="ProtoUnit">AbstractInfantry</target>
            </effect>

            <!-- Unlock units -->
            <!-- Add train buttons to Military Encampment -->
            <effect type="Data" amount="1.00" subtype="Enable" relativity="Absolute">
                <target type="ProtoUnit">ModConscript</target>
            </effect>
            <effect type="CommandAdd" proto="ModConscript" page="0" column="0">
                <target type="ProtoUnit">ModCommandPost</target>
            </effect>

            <effect type="Data" amount="1.00" subtype="Enable" relativity="Absolute">
                <target type="ProtoUnit">deSPCUSVolunteer</target>
            </effect>
            <effect type="CommandAdd" proto="deSPCUSVolunteer" page="0" column="1">
                <target type="ProtoUnit">ModCommandPost</target>
            </effect>


            <!-- Remove 'this' tech to reuse its slot in the UI with incoming unlocks -->
            <effect type="CommandRemove" tech="ModConscription">
                <target type="ProtoUnit">ModCommandPost</target>
            </effect>

            <!-- Add new techs -->
            <effect type="TechStatus" status="obtainable">ModVeteranConscript</effect>
            <effect type="CommandAdd" tech="ModVeteranConscript" page="1" column="0">
                <target type="ProtoUnit">ModCommandPost</target>
            </effect>

            <effect type="TechStatus" status="obtainable">ModImperialVolunteer</effect>
            <effect type="CommandAdd" tech="ModImperialVolunteer" page="1" column="1">
                <target type="ProtoUnit">ModCommandPost</target>
            </effect>

            <effect type="TechStatus" status="obtainable">ModWeaponsTraining</effect>
            <effect type="CommandAdd" tech="ModWeaponsTraining" page="2" column="0">
                <target type="ProtoUnit">ModCommandPost</target>
            </effect>
        </effects>
    </tech>

